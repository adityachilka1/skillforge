{
  "name": "@adityachilka/skillforge",
  "version": "0.0.1",
  "description": "CLI for authoring Claude Skills — scaffold, validate, and lint SKILL.md files.",
  "keywords": [
    "claude",
    "claude-skills",
    "skills",
    "anthropic",
    "ai-agents",
    "mcp",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "author": "Aditya Chilka <https://github.com/adityachilka1>",
  "homepage": "https://github.com/adityachilka1/skillforge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityachilka1/skillforge.git"
  },
  "bugs": "https://github.com/adityachilka1/skillforge/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skillforge": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write ."
  },
  "dependencies": {
    "cac": "^6.7.14",
    "gray-matter": "^4.0.3",
    "kleur": "^4.1.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
